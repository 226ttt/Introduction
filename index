        let currentLang = localStorage.getItem('lang') || 'th';
        let currentTheme = localStorage.getItem('theme') || 'light';

        // Dark/Light Theme Handler
        function initTheme() {
            document.documentElement.setAttribute('data-theme', currentTheme);
            document.getElementById('theme-toggle').textContent = currentTheme === 'light' ? '🌙' : '☀️';
        }

        function toggleTheme() {
            currentTheme = currentTheme === 'light' ? 'dark' : 'light';
            localStorage.setItem('theme', currentTheme);
            initTheme();
        }

        function toggleLang() {
            currentLang = currentLang === 'th' ? 'en' : 'th';
            localStorage.setItem('lang', currentLang);
            updateText();
        }

        function updateText() {
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (translations[currentLang] && translations[currentLang][key]) {
                    el.textContent = translations[currentLang][key];
                }
            });
            document.documentElement.lang = currentLang;
            document.getElementById('lang-toggle').textContent = currentLang === 'th' ? 'EN' : 'TH';
            syncRotateButton();
        }

        // Mobile Responsive Navigation Menu
        function toggleMobileMenu() { 
            document.getElementById('navMenu').classList.toggle('active'); 
            document.querySelector('.hamburger').classList.toggle('active'); 
        }
        function closeMobileMenu() { 
            document.getElementById('navMenu').classList.remove('active'); 
            document.querySelector('.hamburger').classList.remove('active'); 
            document.getElementById('design-dropdown').classList.remove('open');
        }
        function toggleDropdownMenu(e) {
            e.preventDefault();
            e.stopPropagation();
            document.getElementById('design-dropdown').classList.toggle('open');
        }

        // Section Router UI
        function showSection(sectionId) {
            if (sectionId === 'design3d') sectionId = 'cat3d';
            document.querySelectorAll('.page-section').forEach(sec => sec.classList.add('hidden'));
            const target = document.getElementById(sectionId); 
            if (target) target.classList.remove('hidden');
            
            document.querySelectorAll('.nav-menu > li > a').forEach(a => a.classList.remove('active'));
            const navLink = document.getElementById('nav-' + sectionId); 
            if (navLink) navLink.classList.add('active');
            document.getElementById('design-dropdown').classList.remove('open');

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        window.addEventListener('click', (e) => { 
            if (!e.target.closest('.dropdown')) document.getElementById('design-dropdown').classList.remove('open'); 
            if (!e.target.closest('nav')) closeMobileMenu(); 
        });

        // 3D Model Rotation & Audio Logic
        let isAutoRotating = false; let rotateAnimFrame = null; let currentRotation = 0;
        function startSmoothRotation() {
            if (rotateAnimFrame) cancelAnimationFrame(rotateAnimFrame);
            function animate() {
                if (isAutoRotating) {
                    currentRotation += 1.5;
                    const viewer = document.getElementById('glb-viewer');
                    if (viewer) viewer.cameraOrbit = `${currentRotation}deg auto auto`;
                }
                rotateAnimFrame = requestAnimationFrame(animate);
            }
            animate();
            const audio = document.getElementById('background-music');
            if (audio && isAutoRotating) audio.play().catch(()=>{});
        }
        function stopSmoothRotation() {
            if (rotateAnimFrame) cancelAnimationFrame(rotateAnimFrame);
            rotateAnimFrame = null;
            const audio = document.getElementById('background-music');
            if (audio) audio.pause();
        }
        function toggleAutoRotate() {
            isAutoRotating = !isAutoRotating;
            syncRotateButton();
            if (isAutoRotating) startSmoothRotation(); else stopSmoothRotation();
        }
        function syncRotateButton() {
            const btn = document.getElementById('btn-rotate'); if (!btn) return;
            btn.textContent = isAutoRotating ? translations[currentLang].btn_rotate : (currentLang === 'th' ? '🔄 หมุนอัตโนมัติ' : '🔄 Auto Rotate');
        }
        function resetCamera() { const viewer = document.getElementById('glb-viewer'); currentRotation = 0; if (viewer) viewer.cameraOrbit = '0deg auto auto'; }
        function updateVolume(val) { const audio = document.getElementById('background-music'); const numVal = parseInt(val, 10); if (audio) audio.volume = numVal / 100; document.getElementById('volume-txt-label').textContent = `${numVal}%`; }

        window.addEventListener('DOMContentLoaded', () => {
            initTheme();
            updateText();
            isAutoRotating = true;
            syncRotateButton();
            startSmoothRotation();
        });
    </script>

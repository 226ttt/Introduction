<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Python Data Science Graphing Calculator</title>
    <!-- ดึงคลังแสงภายนอกมาช่วยคำนวณและวาดกราฟ -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjs/11.8.0/math.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            font-family: 'Courier New', Courier, monospace;
            background-color: #1a1a1a;
            color: #ffffff;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }
        .container {
            background-color: #2b2b2b;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.6);
            width: 90%;
            max-width: 600px;
        }
        .header {
            color: #4B8BBE;
            text-align: center;
            margin-bottom: 15px;
            font-weight: bold;
            font-size: 20px;
        }
        .header span { color: #FFD43B; }
        .input-group {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }
        #equation-input {
            flex: 1;
            padding: 12px;
            font-size: 16px;
            background-color: #111;
            border: 1px solid #4B8BBE;
            border-radius: 6px;
            color: #39FF14;
        }
        button {
            padding: 10px 15px;
            font-size: 14px;
            cursor: pointer;
            border: none;
            border-radius: 6px;
            background-color: #4B8BBE;
            color: white;
            font-weight: bold;
            transition: 0.2s;
        }
        button:hover { background-color: #5f9ece; }
        button.btn-plot { background-color: #FFD43B; color: #111; }
        button.btn-plot:hover { background-color: #ffe169; }
        .shortcuts {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin-bottom: 20px;
        }
        .btn-shortcut {
            background-color: #3a3a3a;
            color: #8da2fb;
            font-size: 12px;
            padding: 6px 10px;
        }
        .graph-area {
            background-color: #ffffff;
            border-radius: 6px;
            padding: 10px;
            margin-bottom: 20px;
        }
        .python-ide {
            background-color: #121212;
            padding: 15px;
            border-radius: 6px;
            font-size: 12px;
            color: #a9b7c6;
            border-left: 4px solid #FFD43B;
            overflow-x: auto;
            white-space: pre;
        }
        .keyword { color: #cc7832; }
        .comment { color: #629755; font-style: italic; }
        .builtin { color: #8888c6; }
    </style>
</head>
<body>

<div class="container">
    <div class="header">🐍 Matplotlib_<span>GraphCalc</span></div>
    
    <div class="input-group">
        <input type="text" id="equation-input" value="x^2" placeholder="ใสสมการ เช่น x^2, sin(x), 2*x + 5">
        <button class="btn-plot" onclick="plotGraph()">Plot Graph</button>
    </div>

    <div class="shortcuts">
        <button class="btn-shortcut" onclick="addText('sin(x)')">sin(x)</button>
        <button class="btn-shortcut" onclick="addText('cos(x)')">cos(x)</button>
        <button class="btn-shortcut" onclick="addText('tan(x)')">tan(x)</button>
        <button class="btn-shortcut" onclick="addText('sqrt(x)')">sqrt(x)</button>
        <button class="btn-shortcut" onclick="addText('x^3')">x^3</button>
        <button class="btn-shortcut" onclick="addText('log(x)')">ln(x)</button>
        <button style="background-color: #d32f2f;" onclick="clearInput()">Clear</button>
    </div>

    <!-- พื้นที่วาดกราฟ -->
    <div class="graph-area">
        <canvas id="graphCanvas"></canvas>
    </div>

    <!-- ส่วนที่แปลงร่างเป็น Python Matplotlib Script -->
    <div class="python-ide" id="pyCode"></div>
</div>

<script>
    let chartInstance = null;

    // เริ่มต้นหน้าเว็บให้พลอตกราฟ x^2 ไว้รอเลย
    window.onload = function() {
        plotGraph();
    };

    function addText(text) {
        const input = document.getElementById('equation-input');
        if(input.value === "x^2" && text !== 'x^2') {
            input.value = text;
        } else {
            input.value += text;
        }
    }

    function clearInput() {
        document.getElementById('equation-input').value = "";
    }

    function convertToPythonSyntax(expr) {
        let result = expr;
        result = result.replace(/sin/g, "np.sin");
        result = result.replace(/cos/g, "np.cos");
        result = result.replace(/tan/g, "np.tan");
        result = result.replace(/sqrt/g, "np.sqrt");
        result = result.replace(/log/g, "np.log");
        result = result.replace(/\^/g, "**"); // ยกกำลังใน Python
        return result;
    }

    function plotGraph() {
        const equation = document.getElementById('equation-input').value;
        const xValues = [];
        const yValues = [];

        // ทำการเจนค่า X ตั้งแต่ -10 ถึง 10 ถี่ห่างช่องละ 0.5 เพื่อให้กราฟสมูท
        for (let x = -10; x <= 10; x += 0.5) {
            try {
                // ใช้ math.js คำนวณหาค่า Y จากฟังก์ชันที่กรอกเข้ามา
                let y = math.evaluate(equation, { x: x });
                
                // คัดกรองค่าที่เป็นจำนวนจริง (ไม่เอา NaN หรือตัวเลขสมมุติจินตภาพ)
                if (typeof y === 'number' && isFinite(y)) {
                    xValues.push(x.toFixed(1));
                    yValues.push(y);
                }
            } catch (error) {
                // ถ้าสมการผิดพลาดจะแสดง Error ในกล่อง Python ด้านล่าง
                showPythonError();
                return;
            }
        }

        // อัปเดตกราฟบนหน้าเว็บ
        renderChart(xValues, yValues, equation);
        // อัปเดตโค้ด Python
        updatePythonScript(equation);
    }

    function renderChart(xData, yData, label) {
        const ctx = document.getElementById('graphCanvas').getContext('2d');
        
        // ถ้ามีกราฟเก่าอยู่ให้ทำลายทิ้งก่อน เพื่อวาดอันใหม่ทับ
        if (chartInstance) {
            chartInstance.destroy();
        }

        chartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: xData,
                datasets: [{
                    label: `f(x) = ${label}`,
                    data: yData,
                    borderColor: '#4B8BBE',
                    borderWidth: 2.5,
                    pointRadius: 0, // ไม่แสดงจุดตุ่มๆ เพื่อให้ได้เส้นกราฟที่คลีนแบบวิทยาศาสตร์
                    fill: false
                }]
            },
            options: {
                responsive: true,
                scales: {
                    x: { grid: { color: '#e0e0e0' } },
                    y: { grid: { color: '#e0e0e0' } }
                }
            }
        });
    }

    function updatePythonScript(expr) {
        let pyExpr = convertToPythonSyntax(expr);
        document.getElementById("pyCode").innerHTML = `
<span class="comment"># Python Data Science Script to replicate this plot</span>
<span class="keyword">import</span> matplotlib.pyplot <span class="keyword">as</span> plt
<span class="keyword">import</span> numpy <span class="keyword">as</span> np

<span class="comment"># กำหนดช่วงค่า X จาก -10 ถึง 10 (สร้างจุด 400 จุดให้เส้นกราฟเนียน)</span>
x = np.linspace(-10, 10, 400)

<span class="comment"># ฟังก์ชันสมการคณิตศาสตร์</span>
y = ${pyExpr}

<span class="comment"># สั่งสร้างกราฟด้วย Matplotlib</span>
plt.plot(x, y, label=<span class="builtin">"f(x) = ${expr}"</span>, color=<span class="builtin">'#4B8BBE'</span>)
plt.title(<span class="builtin">"Scientific Graphing Calculator"</span>)
plt.xlabel(<span class="builtin">"X Axis"</span>)
plt.ylabel(<span class="builtin">"Y Axis"</span>)
plt.grid(<span class="keyword">True</span>)
plt.legend()

<span class="comment"># แสดงผลกราฟหน้าต่างป็อปอัป</span>
plt.show()
        `.trim();
    }

    function showPythonError() {
        document.getElementById("pyCode").innerHTML = `
<span class="comment"># Python Traceback (Invalid Equation)</span>
<span class="keyword">import</span> sys
<span class="builtin">print</span>(<span class="builtin">"SyntaxError: รูปแบบสมการไม่ถูกต้อง กรุณาตรวจสอบวงเล็บ หรือเครื่องหมายคูณ เช่น 2*x"</span>)
        `.trim();
    }
</script>

</body>
</html>
